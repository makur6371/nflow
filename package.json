{"name": "nflow", "version": "1.0.0", "description": "AI Novel Writing CLI Tool - Reliable, Free, Powerful", "main": "./index.js", "type": "module", "bin": {"nflow": "./dist/index.cjs"}, "repository": {"type": "git", "url": "https://github.com/your-username/nflow"}, "keywords": ["nflow", "ai", "novel", "writing", "creative-writing", "cli", "fiction", "story", "ai-writer", "novel-generator", "fiction-writer", "creative-ai", "story-writer"], "author": "nflow contributors", "license": "MIT", "workspaces": ["packages/*"], "scripts": {"build": "npm run build:cli && npm run build:core", "build:cli": "cd packages/cli && npm run build", "build:core": "cd packages/core && npm run build", "test": "npm run test:cli && npm run test:core", "test:cli": "cd packages/cli && npm test", "test:core": "cd packages/core && npm test", "lint": "eslint . --ext .ts,.tsx,.js,.jsx", "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"", "dev": "npm run build && node ./dist/index.js", "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"}, "devDependencies": {"@types/node": "^22.0.0", "@typescript-eslint/eslint-plugin": "^7.0.0", "@typescript-eslint/parser": "^7.0.0", "esbuild": "^0.20.0", "eslint": "^8.57.0", "prettier": "^3.2.5", "typescript": "^5.3.3", "vitest": "^1.3.1"}, "engines": {"node": ">=20.0.0", "npm": ">=9.0.0"}}