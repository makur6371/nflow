{"name": "@nflow/cli", "version": "1.0.0", "description": "nflow CLI Application - AI Novel Writing Assistant", "main": "./dist/index.js", "bin": {"nflow": "./dist/index.js"}, "scripts": {"build": "tsc && esbuild src/index.ts --bundle --platform=node --outfile=../../dist/index.cjs --external:react --external:ink --external:@nflow/core --external:commander --external:chalk --format=cjs", "dev": "tsc --watch", "test": "vitest", "lint": "eslint src --ext .ts,.tsx"}, "dependencies": {"@nflow/core": "^1.0.0", "ink": "^4.4.1", "react": "^18.2.0", "commander": "^12.0.0", "chalk": "^5.3.0"}, "devDependencies": {"@types/node": "^22.0.0", "@types/react": "^18.2.0", "typescript": "^5.3.3", "vitest": "^1.3.1", "esbuild": "^0.20.0"}, "engines": {"node": ">=20.0.0"}}